# Ultrawhale Raspberry Pi 3B+ profile using OpenRouter auto routing.
# Copy to /etc/ultrawhale/openrouter.env and chmod 600.

OPENROUTER_API_KEY=
LLM_HOST=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/auto

# Optional upload/curation. Upload service is harmless without HF_TOKEN, but upload will warn.
HF_TOKEN=
ULTRAWHALE_HF_REPO=PeetPedro/ultrawhale-dogfood

# Conservative Pi 3B+ defaults.
ULTRAWHALE_MAX_WORKERS=1
ULTRAWHALE_MIN_WORKERS=1
ULTRAWHALE_MAX_MEMORY_PCT=70
ULTRAWHALE_MAX_CPU_PCT=80
ULTRAWHALE_MIN_SCORE=0.65
ULTRAWHALE_NUM_PAIRS=999999
ULTRAWHALE_CATEGORY=cs

ULTRAWHALE_OUTPUT_DIR=/var/lib/ultrawhale
ULTRAWHALE_LOG_DIR=/var/log/ultrawhale

# Tailnet-only status server. Leave host unset to bind to `tailscale ip -4`.
ULTRAWHALE_TAILNET_STATUS_PORT=8765
ULTRAWHALE_TAILNET_STATUS_LINES=120
# ULTRAWHALE_TAILNET_STATUS_HOST=100.x.y.z
